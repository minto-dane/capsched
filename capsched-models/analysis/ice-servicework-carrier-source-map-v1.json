      "VF active bit",
      "queue id range check",
      "PTP clock callback reachability",
      "DPLL subsystem callback reachability",
      "switchdev FDB notification",
      "bridge aging event",
      "LAG netdev notifier event",
      "lower_dev rewrite"
    ]
  },
