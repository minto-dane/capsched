  "required_invariants": [
    "No service-only worker may produce queue, DMA, IRQ, offload, or caller control effects",
    "No VF mailbox request may configure queues, DMA ring addresses, IRQ maps, bandwidth, quanta, RSS/VLAN/FDIR, or PTP state without a VF/Domain request carrier and endpoint-specific authority",
    "No merged service loop may authorize effects by a mutable last caller",
    "No PTP or DPLL deferred worker may apply caller-requested control changes without a live caller control carrier",
    "No bridge or switchdev event may install or replay hardware rules without OffloadCap, policy generation, and lower QueueLease binding where needed",
    "No LAG lower_dev rewrite may preserve representor lower QueueLease authority without a fresh lower rebind",
    "No reset, rebuild, or service replay after revoke may restore old queue/offload/PTP state without fresh epoch and endpoint reauthorization"
  ],
  "forbidden_claims": [
    "pf->serv_task is a safe ambient authority root",
    "ICE_SERVICE_SCHED coalescing preserves caller provenance",
    "virtchnl allowlists are QueueLease authority",
    "VF active state is Domain authority",
    "PTP/DPLL worker identity is user control authority",
    "switchdev/FDB/LAG policy events are lower QueueLease authority",
    "reset/rebuild replay is automatically safe after revoke"
  ],
  "next_model": "formal/0037-modern-nic-servicework-carrier-model"
