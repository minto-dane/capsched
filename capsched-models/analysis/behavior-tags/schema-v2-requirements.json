  "hard_reject_tags": [
    "observation_only_satisfies_security_claim",
    "linux_mutable_shadow_as_production_root",
    "cluster_consensus_in_wake_pick_switch",
    "remote_rpc_in_scheduler_hot_path",
    "raw_cluster_lease_as_executable_authority",
    "failure_action_not_modeled_for_enforcement",
    "unknown_safety_field_for_enforcement",
    "enqueue_task_fail_capable_without_rollback",
    "TASK_WAKING_then_reject",
    "pick_retry_after_class_state_mutation_without_model",
    "switch_activation_failure_without_fail_closed_model",
    "global_task_scan_in_hot_path",
    "sleeping_allocation_in_hot_path",
    "public_abi_from_observation_slice"
  ],
  "solver_eligibility": {
    "required": [
      "claim_scope is explicit",
      "enforcement_strength is not observation_only for enforcement selection",
      "trust_root is compatible with claim_scope",
      "attacker_mutability is compatible with threat model",
      "failure_action is modeled",
      "revocation_scope and stop point are explicit",
      "ordering_context is known or conservatively modeled",
      "cost and benefit vectors define polarity",
      "evidence confidence is explicit"
    ],
    "forbidden": [
      "unknown safety fields",
      "mixed-polarity numeric vectors",
      "unbounded revocation for production enforcement",
      "distributed authority acquisition in scheduler hot path"
    ]
  }
