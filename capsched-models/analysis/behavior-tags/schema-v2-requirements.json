{
  "schema_version": 1,
  "updated": "2026-06-27",
  "purpose": "Requirements for behavior tag schema v2 before any tag-driven CapSched hook selection.",
  "status": "requirements_only",
  "not_yet": [
    "not a behavior tag ledger",
    "not a solver input",
    "not enforcement evidence",
    "not production security evidence"
  ],
  "core_rules": [
    {
      "id": "RULE-001",
      "text": "Safety, security, compatibility, trust-root, and claim-scope constraints are hard filters, never weighted objectives."
    },
    {
      "id": "RULE-002",
      "text": "Observation coverage must never satisfy enforcement or production security obligations."
    },
    {
      "id": "RULE-003",
      "text": "Linux-only L0 evidence must never satisfy monitor-backed CapSched-H production claims."
    },
    {
      "id": "RULE-004",
      "text": "Unknown safety fields make a candidate ineligible for enforcement selection."
    },
    {
      "id": "RULE-005",
      "text": "Cost and benefit vectors must be separate and must define polarity, unit, unknown policy, and evidence source."
    },
    {
      "id": "RULE-006",
      "text": "Scheduler hot paths may validate only local compiled authority; they must not acquire distributed authority."
    }
  ],
  "mandatory_fields": {
    "identity": {
      "id": "stable unique id",
      "kind": "behavior_path | hook_candidate | hard_constraint | objective",
      "description": "short human-readable description",
      "source_anchors": "list of file:line or function anchors"
    },
    "claim_boundary": {
      "claim_scope": [
        "l0_observation",
        "l0_linux_enforcement",
        "caph_monitor_enforced",
        "caph_hardware_enforced"
      ],
      "enforcement_strength": [
        "observation_only",
        "debug_assert",
        "default_permissive",
        "fail_closed_linux",
        "fail_closed_monitor",
        "hardware_enforced"
      ],
      "proof_status": [
        "unmodeled",
        "model_required",
        "model_passed",
        "counterexample_known",
        "linux_observed",
        "protection_evidenced"
      ]
    },
    "trust_and_mutability": {
      "trust_root": [
        "linux_mutable_shadow",
        "monitor_sealed_token",
        "monitor_epoch",
        "hardware_memory_view",
        "iommu_irq_root",
        "service_endpoint",
        "cluster_compiled_local_authority"
      ],
      "attacker_mutability": [
