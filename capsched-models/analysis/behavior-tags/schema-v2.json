  "hard_reject_rules": [
    {
      "id": "HR-001",
      "text": "Observation-only evidence cannot satisfy enforcement or production security obligations."
    },
    {
      "id": "HR-002",
      "text": "Linux mutable shadow state cannot be a CapSched-H production authority root."
    },
    {
      "id": "HR-003",
      "text": "Unknown failure action makes an enforcement hook candidate invalid."
    },
    {
      "id": "HR-004",
      "text": "Fail-capable enqueue after irreversible scheduler accounting is invalid without rollback model."
    },
    {
      "id": "HR-005",
      "text": "TASK_WAKING then reject is invalid without a lost-wakeup and ordering model."
    },
    {
      "id": "HR-006",
      "text": "Pick retry after scheduler class mutation is invalid without class-state model."
    },
    {
      "id": "HR-007",
      "text": "Switch activation failure is invalid without fail-closed monitor or CPU isolation semantics."
    },
    {
      "id": "HR-008",
      "text": "Scheduler hot paths must not acquire distributed authority, perform remote RPC, or run cluster consensus."
    },
    {
      "id": "HR-009",
      "text": "Unknown safety, trust-root, revocation, ordering, or class semantics cannot be treated as a favorable value."
    },
    {
      "id": "HR-010",
      "text": "Security invariants must not be averaged into a numeric score."
    }
  ],
  "performance_vector_contract": {
    "event_frequency": {
      "direction": "informational",
