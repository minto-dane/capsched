  "hard_constraints": [
    {
      "id": "HC-001",
      "text": "A behavior-changing enforcement hook must not be placed after irreversible scheduler accounting mutation unless rollback or nofail semantics are modeled."
    },
    {
      "id": "HC-002",
      "text": "No hook may sleep, allocate, or perform slow capability-table lookup while rq locks, p->pi_lock, raw IRQ-disabled regions, or scheduler class callback locks are held."
    },
    {
      "id": "HC-003",
      "text": "No selected non-idle task requiring CapSched authority may run without a live FrozenRunUse in any enforcement model."
    },
    {
      "id": "HC-004",
      "text": "Queued migration may refresh placement authority but must not mint broader RunCap authority."
    },
    {
      "id": "HC-005",
      "text": "Current self-wake must not be treated as a new runqueue submission authority event."
    },
    {
      "id": "HC-006",
      "text": "Remote-pending wake state must be invalidated by relevant epoch revocation before execution can occur."
    },
    {
      "id": "HC-007",
      "text": "CONFIG_CAPSCHED=n must preserve upstream behavior and layout unless a separate gate explicitly approves otherwise."
    },
    {
      "id": "HC-008",
      "text": "Optimization may minimize cost only after security obligations are covered."
    }
  ],
  "soft_cost_dimensions": {
