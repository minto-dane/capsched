    "ring_full_count",
    "drop_count",
    "batch_size",
    "transition_cost",
    "service_latency",
    "carrier_preference"
  ],
  "carrier_selection_guidance": {
    "direct_call": [
      "reference_path",
      "low_volume_query_control_revoke_ring_health_operations",
      "emergency_shadow_refresh_still_budgeted_and_monitor_validated"
    ],
