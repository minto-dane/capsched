    "no_dependence_on_compromised_linux_consuming_responses"
  ],
  "invariants": [
    "no_carrier_local_admission_authority",
    "no_carrier_local_replay_namespace",
    "no_carrier_local_success_ledger",
    "no_carrier_local_shadow_generation",
    "no_response_without_shared_monitor_ledger",
    "no_success_without_canonical_monitor_attempt",
    "no_success_without_shared_replay_consume",
    "no_duplicate_success_across_direct_ring_fallback_for_one_replay_key",
