        "interrupt_remapping_receipt_when_production_backed"
      ],
      "forbidden_shortcut": "vector_id range check, q_vector lookup, or ice_cfg_interrupt success as IRQ route ownership"
    },
    {
      "name": "QueueBudgetCarrier",
      "required_fields": [
        "vf_request_carrier",
        "queuelease_id",
        "queue_epoch",
        "budget_or_rate_authority",
        "traffic_class",
        "peak_committed_limits_or_quanta_profile"
      ],
      "forbidden_shortcut": "QoS caps, rate fields, or traffic class checks as queue budget authority"
    },
    {
      "name": "FdirOffloadCarrier",
      "required_fields": [
        "vf_request_carrier",
        "offload_or_queuecontrol_cap",
        "rule_generation",
        "flow_id",
        "destination_queue_or_action_digest",
        "ctrl_vsi_generation",
        "async_completion_context_id"
      ],
      "forbidden_shortcut": "FDIR rule validation, ctx_irq, ctx_done, timer, IRQ, or service flush as frozen OffloadCap"
    }
