{
  "schema_version": 1,
  "date": "2026-06-30",
  "scope": "Intel ice VF mailbox QueueControl, DMA ring-address, IRQ route, queue budget, and FDIR/offload carrier semantics",
  "status": "source_observed_only",
  "authority_root": {
    "required": "service Domain authority plus VF/Domain request carrier and operation-specific QueueLease, QueueControl, DMA MemoryView, IRQ route, QueueBudget, or Offload authority",
    "not_authority": [
      "virtchnl_vc_validate_vf_msg success",
      "ice_vc_is_opcode_allowed success",
      "vf object reachability",
      "vf->cfg_lock serialization",
      "ICE_VF_STATE_ACTIVE",
      "ICE_VF_VSI_ID equality",
      "queue id range validation",
      "ring length validation",
      "vector id range validation",
      "driver_caps negotiation",
      "opcodes_allowlist bit",
      "rxq_ena bit",
      "txq_ena bit",
      "ICE_VF_STATE_QS_ENA",
      "FDIR ctx_irq valid bit",
      "FDIR ctx_done valid bit",
      "FDIR timer or IRQ completion",
      "service task flush"
    ]
  },
  "carrier_classes": [
    {
      "name": "VFRequestCarrier",
      "required_fields": [
        "vf_domain_id",
        "vf_id",
        "vf_epoch",
