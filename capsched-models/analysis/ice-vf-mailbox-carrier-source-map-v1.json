        "prior_queue_config_generation",
        "irq_route_status_if_interrupts_enabled"
      ],
      "forbidden_shortcut": "rxq_ena, txq_ena, ICE_VF_STATE_QS_ENA, or successful queue stop as QueueLease authority"
    },
    {
      "name": "IrqRouteCarrier",
      "required_fields": [
        "vf_request_carrier",
        "irq_route_id",
        "irq_route_epoch",
        "vf_vector_id",
        "queue_bitmap",
