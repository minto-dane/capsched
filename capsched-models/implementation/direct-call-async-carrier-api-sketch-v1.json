  "adapter_contracts": [
    {
      "adapter": "workqueue",
      "scope": "typed_wrapper_for_domain_originated_work_only",
      "not_global_hook": true,
      "adapter_steps": [
        {
          "step_id": "WQAPI-001",
          "name": "prepare",
          "requires_core_ops": ["create_empty", "freeze", "bind"],
          "rule": "create empty carrier, freeze caller, and bind service/resource authority before queue publication"
        },
        {
          "step_id": "WQAPI-002",
          "name": "queue",
          "requires_core_ops": ["freeze", "bind"],
          "rule": "publish immutable carrier before queue_work_on"
        },
        {
          "step_id": "WQAPI-003",
          "name": "queue_work_false",
          "requires_core_ops": [],
          "rule": "preserve first caller, first BudgetTicket, first receipt, and first carrier generation; second candidate remains caller_adapter_owned and must be rejected, settled, and released exactly once without transferring its budget or receipt"
        },
        {
          "step_id": "WQAPI-004",
          "name": "mod_delayed_work",
          "requires_core_ops": [],
          "rule": "preserve existing carrier, reject new caller, or use explicit monitor-approved regeneration path; silent merge forbidden"
        },
        {
          "step_id": "WQAPI-005",
          "name": "self_requeue",
          "requires_core_ops": ["revoke_check"],
          "rule": "does not refresh receipt, generation, or caller BudgetTicket"
        },
        {
          "step_id": "WQAPI-006",
          "name": "cancel_flush",
          "requires_core_ops": ["revoke_check"],
          "rule": "synchronization only; not monitor revoke receipt and not settlement proof"
        },
        {
          "step_id": "WQAPI-007",
          "name": "callback_entry",
          "requires_core_ops": ["validate"],
          "rule": "recover typed carrier through adapter container and validate before service side effects"
        },
        {
          "step_id": "WQAPI-008",
          "name": "free",
          "requires_core_ops": ["settle", "release"],
          "rule": "free only after settle/release or never-published discard"
        }
      ]
    },
    {
      "adapter": "io_uring",
      "scope": "explicit_request_or_resource_storage_only",
      "not_generic_io_wq_hook": true,
      "adapter_steps": [
        {
          "step_id": "IOAPI-001",
          "name": "request_creation",
          "requires_core_ops": ["create_empty"],
          "rule": "no authority from allocation"
        },
        {
          "step_id": "IOAPI-002",
          "name": "sqe_consumption",
          "requires_core_ops": ["freeze"],
          "rule": "freeze after SQE is copied or consumed and before side effects"
        },
        {
          "step_id": "IOAPI-003",
          "name": "resource_binding",
          "requires_core_ops": ["bind"],
          "rule": "fixed file and buffer authority are frozen or generation-checked explicitly; io_rsrc_node liveness is not authority"
        },
        {
          "step_id": "IOAPI-004",
          "name": "inline_issue",
          "requires_core_ops": ["validate"],
          "rule": "validate before __io_issue_sqe side effects"
        },
        {
          "step_id": "IOAPI-005",
          "name": "io_wq_punt",
          "requires_core_ops": ["validate"],
          "rule": "publish immutable carrier before worker execution and validate before io_wq_submit_work side effects"
        },
        {
          "step_id": "IOAPI-006",
          "name": "linked_requests",
          "requires_core_ops": ["freeze", "bind"],
          "rule": "each request has a carrier or explicit child/split relationship; linkage is not authority inheritance"
        },
        {
          "step_id": "IOAPI-007",
          "name": "cancel",
          "requires_core_ops": ["revoke_check"],
          "rule": "Linux cancel state is matching/synchronization only, not monitor revoke receipt"
        },
        {
          "step_id": "IOAPI-008",
          "name": "reissue",
          "requires_core_ops": ["revoke_check", "validate"],
          "rule": "REQ_F_REISSUE preserves original carrier or uses explicit monitor-approved replacement; no implicit receipt refresh"
        },
        {
          "step_id": "IOAPI-009",
          "name": "completion_cqe",
          "requires_core_ops": ["settle"],
          "rule": "CQE is result delivery only, not monitor verification, receipt minting, or settlement proof; settlement-affecting completion must pass through carrier settlement state"
        },
        {
          "step_id": "IOAPI-010",
          "name": "resource_ref_release_free",
          "requires_core_ops": ["release"],
          "rule": "storage lifetime only; not EndpointCap revoke or receipt settlement"
        }
      ]
    }
  ],
