  "required_lifecycle_anchors": {
    "raw_copy_reset": {
      "file": "kernel/fork.c",
      "function": "dup_task_struct",
      "after_pattern": "RCU_INIT_POINTER(tsk->exec_state, NULL)",
      "before_pattern": "setup_thread_stack(tsk, orig)",
      "reason": "arch_dup_task_struct raw-copies parent task bytes"
    },
    "child_identity_prepare": {
      "file": "kernel/fork.c",
      "function": "copy_process",
      "after_patterns": [
        "PF_KTHREAD",
        "PF_IO_WORKER",
        "copy_creds"
      ],
      "before_pattern": "No more failure paths after this point.",
      "must_cover": [
        "kernel_clone before wake_up_new_task",
        "create_io_thread inactive return path"
      ]
    },
    "exec_identity": {
      "file": "fs/exec.c",
      "forbidden_anchor": "sched_exec",
      "allowed_function": "begin_new_exec",
      "minimum_anchor": "bprm->point_of_no_return = true",
      "preferred_if_generation_means_thread_group_commit": "after de_thread(me) succeeds",
      "preferred_if_generation_means_new_mm_visible": "after exec_mmap(bprm) succeeds"
    },
    "exit_invalidate": {
      "file": "kernel/exit.c",
      "function": "do_exit",
      "after_pattern": "exit_signals(tsk);",
      "reason": "exit_signals sets PF_EXITING"
    }
  },
